{"107:1":{"a":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ","k":"Видел ли ты того, кто считает ложью воздаяние?","t":"Ara'ayta Al-Ladhi Yukadhibu Bid-Dini"},"107:2":{"a":"فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ","k":"Это - тот, кто гонит сироту","t":"Fadhalika Al-Ladhi Yadu``u Al-Yatima"},"107:3":{"a":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ","k":"и не побуждает накормить бедняка.","t":"Wa La Yahuđđu `Ala Ta`ami Al-Miskini"},"107:4":{"a":"فَوَيْلٌ لِّلْمُصَلِّينَ","k":"Горе молящимся,","t":"Fawaylun Lilmusallina"},"107:5":{"a":"ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ","k":"которые небрежны к своим намазам,","t":"Al-Ladhina Hum `An Salatihim Sahuna"},"107:6":{"a":"ٱلَّذِينَ هُمْ يُرَآءُونَ","k":"которые лицемерят","t":"Al-Ladhina Hum Yura'una"},"107:7":{"a":"وَيَمْنَعُونَ ٱلْمَاعُونَ","k":"и отказывают даже в мелочи!","t":"Wa Yamna`una Al-Ma`una"}}