{"112:1":{"a":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ هُوَ ٱللَّهُ أَحَدٌ","k":"Скажи: «Он - Аллах Единый,","t":"Qul Huwa Allahu 'Ahadun"},"112:2":{"a":"ٱللَّهُ ٱلصَّمَدُ","k":"Аллах Самодостаточный.","t":"Allahu As-Samadu"},"112:3":{"a":"لَمْ يَلِدْ وَلَمْ يُولَدْ","k":"Он не родил и не был рожден,","t":"Lam Yalid Wa Lam Yulad"},"112:4":{"a":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ","k":"и нет никого равного Ему».","t":"Walam Yakun Lahu Kufuan 'Ahadun"}}