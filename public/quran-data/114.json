{"114:1":{"a":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ","k":"Скажи: «Прибегаю к защите Господа людей,","t":"Qul 'A`udhu Birabbi An-Nasi"},"114:2":{"a":"مَلِكِ ٱلنَّاسِ","k":"Царя людей,","t":"Maliki An-Nasi"},"114:3":{"a":"إِلَٰهِ ٱلنَّاسِ","k":"Бога людей,","t":"Ilahi An-Nasi"},"114:4":{"a":"مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ","k":"от зла искусителя отступающего (или сжимающегося) при поминании Аллаха,","t":"Min Sharri Al-Waswasi Al-Khannasi"},"114:5":{"a":"ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ","k":"который наущает в груди людей","t":"Al-Ladhi Yuwaswisu Fi Suduri An-Nasi"},"114:6":{"a":"مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ","k":"и бывает из джиннов и людей».","t":"Mina Al-Jinnati Wa An-Nasi"}}