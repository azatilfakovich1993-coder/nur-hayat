{"88:1":{"a":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ","k":"Дошел ли до тебя рассказ о Покрывающем (Дне воскресения)?","t":"Hal 'Ataka Hadithu Al-Ghashiyahi"},"88:2":{"a":"وُجُوهٌ يَوْمَئِذٍ خَٰشِعَةٌ","k":"Одни лица в тот день будут унижены,","t":"Wujuhun Yawma'idhin Khashi`ahun"},"88:3":{"a":"عَامِلَةٌ نَّاصِبَةٌ","k":"изнурены и утомлены.","t":"Amilatun Nasibahun"},"88:4":{"a":"تَصْلَىٰ نَارًا حَامِيَةً","k":"Они войдут в Огонь жаркий.","t":"Tasla Naraan Hamiyahan"},"88:5":{"a":"تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍ","k":"Их будут поить из источника кипящего","t":"Tusqa Min `Aynin 'Aniyahin"},"88:6":{"a":"لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ","k":"и кормить только ядовитыми колючками,","t":"Laysa Lahum Ta`amun 'Illa Min Đari`in"},"88:7":{"a":"لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ","k":"от которых не поправляются и которые не утоляют голода.","t":"La Yusminu Wa La Yughni Min Ju`in"},"88:8":{"a":"وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ","k":"Другие же лица в тот день будут радостны.","t":"Wujuhun Yawma'idhin Na`imahun"},"88:9":{"a":"لِّسَعْيِهَا رَاضِيَةٌ","k":"Они будут довольны своими стараниями","t":"Lisa`yiha Rađiyahun"},"88:10":{"a":"فِى جَنَّةٍ عَالِيَةٍ","k":"в Вышних садах.","t":"Fi Jannatin `Aliyahin"},"88:11":{"a":"لَّا تَسْمَعُ فِيهَا لَٰغِيَةً","k":"Они не услышат там словоблудия.","t":"La Tasma`u Fiha Laghiyahan"},"88:12":{"a":"فِيهَا عَيْنٌ جَارِيَةٌ","k":"Там есть источник текущий.","t":"Fiha `Aynun Jariyahun"},"88:13":{"a":"فِيهَا سُرُرٌ مَّرْفُوعَةٌ","k":"Там воздвигнуты ложа,","t":"Fiha Sururun Marfu`ahun"},"88:14":{"a":"وَأَكْوَابٌ مَّوْضُوعَةٌ","k":"расставлены чаши,","t":"Wa 'Akwabun Mawđu`ahun"},"88:15":{"a":"وَنَمَارِقُ مَصْفُوفَةٌ","k":"разложены подушки,","t":"Wa Namariqu Masfufahun"},"88:16":{"a":"وَزَرَابِىُّ مَبْثُوثَةٌ","k":"и разостланы ковры.","t":"Wa Zarabiyu Mabthuthahun"},"88:17":{"a":"أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ","k":"Неужели они не видят, как созданы верблюды,","t":"Afala Yanzuruna 'Ila Al-'Ibili Kayfa Khuliqat"},"88:18":{"a":"وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ","k":"как вознесено небо,","t":"Wa 'Ila As-Sama'i Kayfa Rufi`at"},"88:19":{"a":"وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ","k":"как водружены горы,","t":"Wa 'Ila Al-Jibali Kayfa Nusibat"},"88:20":{"a":"وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ","k":"как распростерта земля?","t":"Wa 'Ila Al-'Arđi Kayfa Sutihat"},"88:21":{"a":"فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌ","k":"Наставляй же, ведь ты - наставник,","t":"Fadhakkir 'Innama 'Anta Mudhakkirun"},"88:22":{"a":"لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ","k":"и ты не властен над ними.","t":"Lasta `Alayhim Bimusaytirin"},"88:23":{"a":"إِلَّا مَن تَوَلَّىٰ وَكَفَرَ","k":"А тех, кто отвернется и не уверует,","t":"Illa Man Tawalla Wa Kafara"},"88:24":{"a":"فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ","k":"Аллах подвергнет величайшим мучениям.","t":"Fayu`adhibuhu Allahu Al-`Adhaba Al-'Akbara"},"88:25":{"a":"إِنَّ إِلَيْنَآ إِيَابَهُمْ","k":"К Нам они вернутся,","t":"Inna 'Ilayna 'Iabahum"},"88:26":{"a":"ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم","k":"и затем Мы потребуем у них отчета.","t":"Thumma 'Inna `Alayna Hisabahum"}}