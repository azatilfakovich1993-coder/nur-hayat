{"80:1":{"a":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ","k":"Он нахмурился и отвернулся,","t":"Abasa Wa Tawalla"},"80:2":{"a":"أَن جَآءَهُ ٱلْأَعْمَىٰ","k":"потому что к нему подошел слепой.","t":"An Ja'ahu Al-'A`ma"},"80:3":{"a":"وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ","k":"Откуда тебе знать? Возможно, он бы очистился","t":"Wa Ma Yudrika La`allahu Yazzakka"},"80:4":{"a":"أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ","k":"или помянул бы наставление, и поминание принесло бы ему пользу.","t":"Aw Yadhakkaru Fatanfa`ahu Adh-Dhikra"},"80:5":{"a":"أَمَّا مَنِ ٱسْتَغْنَىٰ","k":"Тому, кто решил, что он ни в чем не нуждается,","t":"Amma Mani Astaghna"},"80:6":{"a":"فَأَنتَ لَهُۥ تَصَدَّىٰ","k":"ты уделяешь внимание,","t":"Fa'anta Lahu Tasadda"},"80:7":{"a":"وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ","k":"Что же будет тебе, если он не очистится?","t":"Wa Ma `Alayka 'Alla Yazzakka"},"80:8":{"a":"وَأَمَّا مَن جَآءَكَ يَسْعَىٰ","k":"А того, кто приходит к тебе со рвением","t":"Wa 'Amma Man Ja'aka Yas`a"},"80:9":{"a":"وَهُوَ يَخْشَىٰ","k":"и страшится Аллаха,","t":"Wa Huwa Yakhsha"},"80:10":{"a":"فَأَنتَ عَنْهُ تَلَهَّىٰ","k":"ты оставляешь без внимания.","t":"Fa'anta `Anhu Talahha"},"80:11":{"a":"كَلَّآ إِنَّهَا تَذْكِرَةٌ","k":"Но нет! Это есть Назидание,","t":"Kalla 'Innaha Tadhkirahun"},"80:12":{"a":"فَمَن شَآءَ ذَكَرَهُۥ","k":"и пусть помянет его всякий желающий.","t":"Faman Sha'a Dhakarahu"},"80:13":{"a":"فِى صُحُفٍ مُّكَرَّمَةٍ","k":"Оно записано в свитках почитаемых,","t":"Fi Suhufin Mukarramahin"},"80:14":{"a":"مَّرْفُوعَةٍ مُّطَهَّرَةٍۭ","k":"вознесенных и очищенных,","t":"Marfu`atin Mutahharahin"},"80:15":{"a":"بِأَيْدِى سَفَرَةٍ","k":"в руках посланцев","t":"Bi'aydi Safarahin"},"80:16":{"a":"كِرَامٍۭ بَرَرَةٍ","k":"благородных и покорных.","t":"Kiramin Bararahin"},"80:17":{"a":"قُتِلَ ٱلْإِنسَٰنُ مَآ أَكْفَرَهُۥ","k":"Да сгинет человек! Как же он неблагодарен!","t":"Qutila Al-'Insanu Ma 'Akfarahu"},"80:18":{"a":"مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ","k":"Из чего Он сотворил его?","t":"Min 'Ayyi Shay'in Khalaqahu"},"80:19":{"a":"مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ","k":"Он сотворил его из капли и соразмерил (или предопределил стадии его развития),","t":"Min Nutfatin Khalaqahu Faqaddarahu"},"80:20":{"a":"ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ","k":"потом облегчил ему путь,","t":"Thumma As-Sabila Yassarahu"},"80:21":{"a":"ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ","k":"потом умертвил его и поместил в могилу.","t":"Thumma 'Amatahu Fa'aqbarahu"},"80:22":{"a":"ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ","k":"Потом, когда пожелает, Он воскресит его.","t":"Thumma 'Idha Sha'a 'Ansharahu"},"80:23":{"a":"كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ","k":"Но нет! Он не выполняет того, что Он приказал ему.","t":"Kalla Lamma Yaqđi Ma 'Amarahu"},"80:24":{"a":"فَلْيَنظُرِ ٱلْإِنسَٰنُ إِلَىٰ طَعَامِهِۦٓ","k":"Пусть посмотрит человек на свое пропитание!","t":"Falyanzuri Al-'Insanu 'Ila Ta`amihi"},"80:25":{"a":"أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّا","k":"Мы проливаем обильные ливни,","t":"Anna Sababna Al-Ma'a Sabbaan"},"80:26":{"a":"ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّا","k":"затем рассекаем землю трещинами","t":"Thumma Shaqaqna Al-'Arđa Shaqqaan"},"80:27":{"a":"فَأَنۢبَتْنَا فِيهَا حَبًّا","k":"и взращиваем на ней зерна,","t":"Fa'anbatna Fiha Habbaan"},"80:28":{"a":"وَعِنَبًا وَقَضْبًا","k":"виноград и люцерну,","t":"Wa `Inabaan Wa Qađbaan"},"80:29":{"a":"وَزَيْتُونًا وَنَخْلًا","k":"маслины и финиковые пальмы,","t":"Wa Zaytunaan Wa Nakhlaan"},"80:30":{"a":"وَحَدَآئِقَ غُلْبًا","k":"сады густые (или с могучими деревьями),","t":"Wa Hada'iqa Ghulbaan"},"80:31":{"a":"وَفَٰكِهَةً وَأَبًّا","k":"фрукты и травы","t":"Wa Fakihatan Wa 'Abbaan"},"80:32":{"a":"مَّتَٰعًا لَّكُمْ وَلِأَنْعَٰمِكُمْ","k":"на пользу вам и вашей скотине.","t":"Mata`aan Lakum Wa Li'an`amikum"},"80:33":{"a":"فَإِذَا جَآءَتِ ٱلصَّآخَّةُ","k":"Когда же раздастся Оглушительный глас,","t":"Fa'idha Ja'ati As-Sakhkhahu"},"80:34":{"a":"يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ","k":"в тот день человек бросит своего брата,","t":"Yawma Yafirru Al-Mar'u Min 'Akhihi"},"80:35":{"a":"وَأُمِّهِۦ وَأَبِيهِ","k":"свою мать и своего отца,","t":"Wa 'Ummihi Wa 'Abihi"},"80:36":{"a":"وَصَٰحِبَتِهِۦ وَبَنِيهِ","k":"свою жену и своих сыновей,","t":"Wa Sahibatihi Wa Banihi"},"80:37":{"a":"لِكُلِّ ٱمْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ","k":"ибо у каждого человека своих забот будет сполна.","t":"Likulli Amri'in Minhum Yawma'idhin Sha'nun Yughnihi"},"80:38":{"a":"وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ","k":"В тот день одни лица будут сиять,","t":"Wujuhun Yawma'idhin Musfirahun"},"80:39":{"a":"ضَاحِكَةٌ مُّسْتَبْشِرَةٌ","k":"смеяться и ликовать.","t":"Đahikatun Mustabshirahun"},"80:40":{"a":"وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ","k":"На других же лицах в тот день будет прах,","t":"Wa Wujuhun Yawma'idhin `Alayha Ghabarahun"},"80:41":{"a":"تَرْهَقُهَا قَتَرَةٌ","k":"покрывающий их мраком.","t":"Tarhaquha Qatarahun"},"80:42":{"a":"أُو۟لَٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ","k":"Это будут неверующие грешники.","t":"Ula'ika Humu Al-Kafaratu Al-Fajarahu"}}