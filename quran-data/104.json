{"104:1":{"a":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ","k":"Горе всякому хулителю и обидчику,","t":"Waylun Likulli Humazatin Lumazahin"},"104:2":{"a":"ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ","k":"который копит состояние и пересчитывает его,","t":"Al-Ladhi Jama`a Malaan Wa `Addadahu"},"104:3":{"a":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ","k":"думая, что богатство увековечит его.","t":"Yahsabu 'Anna Malahu 'Akhladahu"},"104:4":{"a":"كَلَّا لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ","k":"Но нет! Его непременно ввергнут в Огонь сокрушающий.","t":"Kalla Layunbadhanna Fi Al-Hutamahi"},"104:5":{"a":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ","k":"Откуда ты мог знать, что такое Огонь сокрушающий?","t":"Wa Ma 'Adraka Ma Al-Hutamahu"},"104:6":{"a":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ","k":"Это - разожженный Огонь Аллаха,","t":"Naru Allahi Al-Muqadahu"},"104:7":{"a":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ","k":"который вздымается над сердцами.","t":"Allati Tattali`u `Ala Al-'Af'idahi"},"104:8":{"a":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ","k":"Воистину, он сомкнется над ними","t":"Innaha `Alayhim Mu'usadahun"},"104:9":{"a":"فِى عَمَدٍ مُّمَدَّدَةٍۭ","k":"высокими столбами (мученики будут прикованы к этим столбам или врата Ада будут заперты и закреплены этими столбами).","t":"Fi `Amadin Mumaddadahin"}}